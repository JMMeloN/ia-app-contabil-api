// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  CLIENTE
  OPERACIONAL
  ADMIN
}

enum RequestStatus {
  PENDENTE
  PROCESSADA
  CANCELADA
}

// Models
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(CLIENTE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  companies Company[]
  requests  Request[]

  @@map("users")
}

model Company {
  id              String   @id @default(uuid())
  nome            String
  nomeFantasia    String?
  cnpj            String
  email           String
  telefone        String
  endereco        String   // Campo legado (string completa)
  rua             String?
  numero          String?
  bairro          String?
  complemento     String?
  cidade          String
  estado          String   @db.VarChar(2)
  cep             String
  dataAbertura    DateTime?
  regimeTributario String?
  naturezaJuridica String?
  inscricaoMunicipal String?
  inscricaoEstadual  String?
  userId          String
  
  // Campos técnicos avançados NFe.io
  regimeEspecialTributacao    String?  // specialTaxRegime
  numeroJuntaComercial        BigInt?  // companyRegistryNumber
  rpsSerie                    String?  // rpsSerialNumber
  rpsNumero                   BigInt?  // rpsNumber
  aliquotaIss                 Float?   // issRate
  determinacaoImpostoFederal  String?  // federalTaxDetermination
  determinacaoImpostoMunicipal String? // municipalTaxDetermination
  prefeituraLogin             String?  // loginName
  prefeituraSenha             String?  // loginPassword
  valorAutorizacao            String?  // authIssueValue
  
  // Integração e Status
  nfeioCompanyId  String?  @unique
  cityServiceCode String?
  statusFiscal    String?
  ambiente        String?  @default("Development")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  requests Request[]

  // Constraint: Um usuário não pode cadastrar o mesmo CNPJ duas vezes
  @@unique([userId, cnpj])
  @@map("companies")
}

model Request {
  id              String        @id @default(uuid())
  valor           Float
  dataEmissao     DateTime
  observacoes     String?
  status          RequestStatus @default(PENDENTE)
  arquivoUrl      String?
  userId          String
  companyId       String
  
  // Dados do Tomador (quem recebe a nota)
  tomadorNome      String?
  tomadorDocumento String? // CPF ou CNPJ
  tomadorEmail     String?
  
  // Integração NFe.io
  nfeioInvoiceId   String?  // ID da nota no nfe.io
  
  processadoEm    DateTime?
  emissaoAutomatica Boolean     @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("requests")
}
